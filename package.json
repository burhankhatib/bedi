{
  "name": "bedi-delivery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "clear && next dev --webpack",
    "dev:turbo": "clear && next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "import:baladi": "PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/import-baladi.ts",
    "import:baladi:backfill": "PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/import-baladi.ts --backfill-existing",
    "import:baladi:backfill:interactive": "PLAYWRIGHT_BROWSERS_PATH=0 BALADI_HEADLESS=false tsx scripts/import-baladi.ts --backfill-existing --interactive-auth",
    "import:baladi:backfill:overwrite": "PLAYWRIGHT_BROWSERS_PATH=0 BALADI_HEADLESS=false tsx scripts/import-baladi.ts --backfill-existing --interactive-auth --overwrite-all --reset-checkpoint",
    "import:baladi:backfill:reset": "PLAYWRIGHT_BROWSERS_PATH=0 BALADI_HEADLESS=false tsx scripts/import-baladi.ts --backfill-existing --interactive-auth --reset-checkpoint",
    "import:baladi:url": "PLAYWRIGHT_BROWSERS_PATH=0 BALADI_HEADLESS=false tsx scripts/import-baladi.ts --interactive-auth",
    "import:baladi:cat": "PLAYWRIGHT_BROWSERS_PATH=0 BALADI_HEADLESS=false tsx scripts/import-baladi.ts --interactive-auth",
    "seed:subcategories": "tsx scripts/seed-business-subcategories.ts",
    "seed:platform-areas": "tsx scripts/seed-platform-areas.ts",
    "import:talabat": "PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/import-talabat.ts",
    "import:talabat:url": "PLAYWRIGHT_BROWSERS_PATH=0 TALABAT_HEADLESS=false tsx scripts/import-talabat.ts --interactive-auth",
    "import:yummy": "PLAYWRIGHT_BROWSERS_PATH=0 tsx scripts/import-yummy.ts",
    "import:yummy:url": "PLAYWRIGHT_BROWSERS_PATH=0 YUMMY_HEADLESS=false tsx scripts/import-yummy.ts --interactive-auth",
    "deploy": "clear && npm run build && git add . && (git commit -m \"deploy\" || true) && git push origin main",
    "firebase:deploy": "firebase deploy --only firestore:indexes"
  },
  "dependencies": {
