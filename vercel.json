{
  "framework": "nextjs",
  "buildCommand": "next build --webpack",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/auto-delivery-request",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/jobs/process-due",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-morning-message",
      "schedule": "0 7 * * *"
    }
  ]
}
